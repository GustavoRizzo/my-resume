[{"_1":2,"_3":4},"routes/lang-layout",{"_5":160},"routes/lang-home",{"_5":6},"data",{"_7":8,"_9":10},"lang","en","content",{"_11":12,"_13":14,"_15":16,"_17":18},"about",{"_139":140,"_141":142,"_143":144,"_145":146,"_147":148},"expertises",[117,118,119],"experiences",[67,68,69,70,71,72,73,74],"hobbies",{"_19":20,"_21":22},"section",{"_30":64,"_65":66},"topics",[23,24,25],{"_26":58,"_28":59,"_30":60,"_32":61,"_34":62,"_36":63},{"_26":48,"_28":49,"_30":50,"_32":51,"_34":52,"_36":53},{"_26":27,"_28":29,"_30":31,"_32":33,"_34":35,"_36":37},"id","side-projects","emoji","🛠️","title","Tools & Pastimes I Build","summary","Taking small everyday annoyances and coding my own fix.","body_html","<p>I love taking a small everyday problem and building my own solution for it. Here are a couple of them:</p><ul><li><b>Quem?</b> — a free, ad-free web version of the \"Who am I?\" party game I play with friends. The Play Store apps are buried in ads and paywalls, so I built my own.</li><li><b>PTAX Converter</b> — in Brazil, invoicing foreign clients means converting the amounts using a special Central Bank rate. The official site is painful to use, so I took their API and wrapped it in a nicer interface.</li></ul>","links",[38,39],{"_40":46,"_42":47,"_44":45},{"_40":41,"_42":43,"_44":45},"label","PTAX Converter","url","https://gustavorizzo.github.io/conversor-ptax-logger/","note","Free · PT-BR only","Play \"Quem?\"","https://gustavorizzo.github.io/game-quem-sou-eu/","open-source","🌱","Open Source","Building on each other's solutions so we all get better technology.","<p>I love the idea behind open source: one person's solution can become a stepping stone for someone else's problem — and that person can give back in the same way. In the end, we all benefit from more mature, more capable technology.</p><p>Right now I'm contributing to a <b>Django&nbsp;+&nbsp;HTMX</b> component library, where I've been collecting the patterns I reach for every day while building real projects.</p>",[54],{"_40":55,"_42":56,"_44":57},"django-sample-components","https://pypi.org/project/django-sample-components/","PyPI","outdoors","🥾","Adventures & Sports","Trails, peaks, volleyball, and a good game of football.","<p>I love the outdoors, and hiking is my thing 🏔️. I've climbed some of the highest peaks in Brazil and once completed a <b>250&nbsp;km</b> long-distance trek. My next big dream — one I plan to make happen soon — is to walk the <b>Camino de Santiago</b>. When I'm not on a trail, you'll find me playing volleyball 🏐 or, like any good Brazilian, soccer ⚽.</p>",[],"Beyond Work","subtitle","What I get up to away from the keyboard — and a few things I build just for fun.",{"_30":111,"_65":112,"_77":113,"_79":114,"_81":115,"_83":116},{"_30":106,"_65":107,"_77":108,"_79":109,"_83":110},{"_30":103,"_65":95,"_77":104,"_79":97,"_81":98,"_83":105},{"_30":100,"_65":95,"_77":101,"_79":97,"_81":98,"_83":102},{"_30":94,"_65":95,"_77":96,"_79":97,"_81":98,"_83":99},{"_30":91,"_65":86,"_77":92,"_79":88,"_81":89,"_83":93},{"_30":85,"_65":86,"_77":87,"_79":88,"_81":89,"_83":90},{"_30":75,"_65":76,"_77":78,"_79":80,"_81":82,"_83":84},"WEB DEVELOPER INTERN","at PUC-RIO at LIRA, the LABORATORY of APPLIED ROBOTIC INTELLIGENCE","text","Engaged in the maintenance and updates of the laboratory's website while providing assistance to researchers in minor tasks.","company_logo","PUC-Rio-Logo.jpg","company_url","https://www.puc-rio.br/","initial_date","2017-02-01","CUSTOMER RELATIONSHIP MANAGER INTERN","at STONE CO","The role encompassed addressing customer inquiries and needs through email, phone, and chat platforms, elucidating product-related queries, and engaging in negotiations related to commercial taxation.","logo-stone.jpg","https://investors.stone.co/","2017-05-01","DATA ANALYST IN LOGISTICS","Responsible for generating and automating KPI reports on internal logistics nationwide in Brazil and discussing them with the leaders of each branch to create improvement plans.","2017-11-01","SOFTWARE DEVELOPER","at ATIVA INVESTIMENTOS","Accountable for the enhancement and maintenance of web applications utilized by both external end-users and internal clients within the company. Stack: Azure, C# (.Net Core), Asp.Net and VUE.js.","logo-ativa.jpg","https://www.ativainvestimentos.com.br/","2018-01-01","PROJECT MANAGER","Managed both in-house development teams and outsourced members. Provided guidance and support in the realm of stock brokerage systems, risk management, investment funds and customer acquisition.","2019-07-01","DATA ANALYST","Co-founded a team responsible for overseeing the entire analytical environment of the company. Extracted and cleaned data (using Pentaho and SSIS), restructured and enriched data to establish a Data Warehouse (utilizing Python and SSAS), and presented information through dashboards (using Power BI) to both company's employees and C-level executives.","2020-11-01","FOUNDER","at DANDO SOPA","After years in the corporate world, my partner and I ventured into entrepreneurship, founding Dando Sopa — a retail ecommerce business. Its name was inspired by a Brazilian expression akin to 'up for grabs'.","logo-dando-sopa.png","2022-08-01","FULL STACK DEVELOPER","at VISIAN SYSTEMS","Worked at a software factory serving UK clients, developing projects including e-commerce platforms, client clustering systems, and a security employee tracking system for Heathrow Airport. Built custom software for the French Government to manage and distribute NGO projects in Africa.","logo-visian.jpg","https://www.visiansystems.com/","2023-02-01",{"_30":134,"_121":135,"_123":136,"_125":137,"_127":138,"_83":116},{"_30":129,"_121":130,"_123":131,"_125":132,"_127":133,"_83":116},{"_30":120,"_121":122,"_123":124,"_125":126,"_127":128,"_83":116},"Project Manager","html_text","Managed both internal and external teams in <b>financial market projects</b>, focusing on stock trading systems, investment funds, and risk management. Ensured timely reporting and progress updates to the C-level executives of the company.","url_img","https://cdn-icons-png.flaticon.com/32/1556/1556324.png","icon","engine","underline_class_css","underline-orange","Data Analyst","<p><b>Data Visualization Tools:</b></p><ul><li>Power BI</li><li>Streamlit</li></ul><p><b>ETL Tools:</b></p><ul><li>Apache Spark</li><li>SSIS</li><li>Pentaho</li></ul><p><b>Database:</b></p><ul style='text-align: left'><li><b>Relational:</b> <span>SQLServer, Oracle, PostgreSQL, MySQL</span></li><li><b>NoSQL:</b> <span>MongoDB</span></li><li><b>OLAP:</b> <span>SSAS, DuckDB</span></li></ul>","https://cdn-icons-png.flaticon.com/32/2329/2329087.png","presentation","underline-blue","Software Developer","<p><b>Backend:</b><br><ul><li>Python (Django, FastAPI)</li><li>C# (.Net Core)</li></ul></p><p><b>Frontend:</b><ul><li>JavaScript/Typescript (VUE, React, NextJS)</li></ul></p><p><b>DevOps:</b><ul><li>Docker</li><li>Cloud (Azure, AWS)</li></ul></p>","https://cdn-icons-png.flaticon.com/32/9423/9423061.png","web","underline-megenta","perfil_img","perfil.png","name","Gustavo Rizzo S. M. de Albuquerque","url_linkedin","https://www.linkedin.com/in/gustavo-albuquerque/","url_github","https://github.com/GustavoRizzo","console_phrases",[149,150,151,152],{"_153":134,"_155":159},{"_153":129,"_155":158},{"_153":120,"_155":157},{"_153":154,"_155":156},"phrase","Technology Lover","color","chartreuse","gold","fuchsia","tomato",{"_7":8}]
