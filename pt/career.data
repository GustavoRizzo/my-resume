[{"_1":2,"_3":4},"routes/lang-layout",{"_5":63},"routes/career",{"_5":6},"data",{"_7":8,"_9":10},"lang","pt","experiences",[11,12,13,14,15,16,17,18],{"_19":57,"_21":58,"_23":59,"_25":60,"_27":61,"_29":62},{"_19":52,"_21":53,"_23":54,"_25":55,"_29":56},{"_19":49,"_21":41,"_23":50,"_25":43,"_27":44,"_29":51},{"_19":46,"_21":41,"_23":47,"_25":43,"_27":44,"_29":48},{"_19":40,"_21":41,"_23":42,"_25":43,"_27":44,"_29":45},{"_19":37,"_21":32,"_23":38,"_25":34,"_27":35,"_29":39},{"_19":31,"_21":32,"_23":33,"_25":34,"_27":35,"_29":36},{"_19":20,"_21":22,"_23":24,"_25":26,"_27":28,"_29":30},"title","ESTAGIÁRIO DE DESENVOLVIMENTO WEB","subtitle","na PUC-RIO no LIRA, o LABORATÓRIO de INTELIGÊNCIA ROBÓTICA APLICADA","text","Atuei na manutenção e atualização do site do laboratório, além de auxiliar os pesquisadores em pequenas tarefas.","company_logo","PUC-Rio-Logo.jpg","company_url","https://www.puc-rio.br/","initial_date","2017-02-01","ESTAGIÁRIO DE RELACIONAMENTO COM O CLIENTE","na STONE CO","Responsável pelo atendimento a dúvidas e necessidades dos clientes via e-mail, telefone e chat, esclarecendo questões relacionadas aos produtos e conduzindo renegociações de taxas.","logo-stone.jpg","https://investors.stone.co/","2017-05-01","ANALISTA DE DADOS EM LOGÍSTICA","Responsável por gerar e automatizar relatórios de KPIs sobre a logística interna em todo o Brasil e discuti-los com os líderes de cada filial para criar planos de melhoria.","2017-11-01","DESENVOLVEDOR DE SOFTWARE","na ATIVA INVESTIMENTOS","Responsável pela evolução e manutenção tanto de aplicações utilizadas pelos clientes da empresa quanto das plataformas internas dos funcionários. Stack: Azure, C# (.Net Core), Asp.Net e VUE.js.","logo-ativa.jpg","https://www.ativainvestimentos.com.br/","2018-01-01","GERENTE DE PROJETOS","Gerenciei tanto equipes internas de desenvolvimento quanto membros terceirizados. Prestei orientação e suporte na área de sistemas de corretagem de ações, gestão de risco, fundos de investimento e captação de clientes.","2019-07-01","ANALISTA DE DADOS","Cofundei a equipe de dados da companhia, estruturando todo o ambiente analítico desde a extração e enriquecimento de dados com Pentaho e SSIS, até a modelagem em Data Warehouse via Python e SSAS, finalizando na entrega de dashboards em Power BI. O objetivo era não apenas fornecer dados estratégicos para o nível executivo, mas também disseminar a cultura analítica e o ferramental necessário para empoderar as áreas operacionais.","2020-11-01","FUNDADOR","na DANDO SOPA","Após anos no mundo corporativo, me aventurei com mais um sócio no empreendedorismo, fundando a Dando Sopa — um negócio de e-commerce varejista.","logo-dando-sopa.png","2022-08-01","DESENVOLVEDOR FULL STACK","na VISIAN SYSTEMS","Atuação como Desenvolvedor Sênior em uma software house britânica com projetos globais. Desenvolvimento de plataformas de e-commerce, sistemas de inteligência de clusterização de clientes e soluções de alta segurança, como o sistema de rastreamento de funcionários para o Aeroporto de Heathrow e a plataforma de avaliação de projetos de ONGs para captação de recursos junto ao Governo Francês.","logo-visian.jpg","https://www.visiansystems.com/","2023-02-01",{"_7":8}]
