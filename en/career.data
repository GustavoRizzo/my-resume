[{"_1":2,"_3":4},"routes/lang-layout",{"_5":63},"routes/career",{"_5":6},"data",{"_7":8,"_9":10},"lang","en","experiences",[11,12,13,14,15,16,17,18],{"_19":57,"_21":58,"_23":59,"_25":60,"_27":61,"_29":62},{"_19":52,"_21":53,"_23":54,"_25":55,"_29":56},{"_19":49,"_21":41,"_23":50,"_25":43,"_27":44,"_29":51},{"_19":46,"_21":41,"_23":47,"_25":43,"_27":44,"_29":48},{"_19":40,"_21":41,"_23":42,"_25":43,"_27":44,"_29":45},{"_19":37,"_21":32,"_23":38,"_25":34,"_27":35,"_29":39},{"_19":31,"_21":32,"_23":33,"_25":34,"_27":35,"_29":36},{"_19":20,"_21":22,"_23":24,"_25":26,"_27":28,"_29":30},"title","WEB DEVELOPER INTERN","subtitle","at PUC-RIO at LIRA, the LABORATORY of APPLIED ROBOTIC INTELLIGENCE","text","Engaged in the maintenance and updates of the laboratory's website while providing assistance to researchers in minor tasks.","company_logo","PUC-Rio-Logo.jpg","company_url","https://www.puc-rio.br/","initial_date","2017-02-01","CUSTOMER RELATIONSHIP MANAGER INTERN","at STONE CO","The role encompassed addressing customer inquiries and needs through email, phone, and chat platforms, elucidating product-related queries, and engaging in negotiations related to commercial taxation.","logo-stone.jpg","https://investors.stone.co/","2017-05-01","DATA ANALYST IN LOGISTICS","Responsible for generating and automating KPI reports on internal logistics nationwide in Brazil and discussing them with the leaders of each branch to create improvement plans.","2017-11-01","SOFTWARE DEVELOPER","at ATIVA INVESTIMENTOS","Accountable for the enhancement and maintenance of web applications utilized by both external end-users and internal clients within the company. Stack: Azure, C# (.Net Core), Asp.Net and VUE.js.","logo-ativa.jpg","https://www.ativainvestimentos.com.br/","2018-01-01","PROJECT MANAGER","Managed both in-house development teams and outsourced members. Provided guidance and support in the realm of stock brokerage systems, risk management, investment funds and customer acquisition.","2019-07-01","DATA ANALYST","Co-founded a team responsible for overseeing the entire analytical environment of the company. Extracted and cleaned data (using Pentaho and SSIS), restructured and enriched data to establish a Data Warehouse (utilizing Python and SSAS), and presented information through dashboards (using Power BI) to both company's employees and C-level executives.","2020-11-01","FOUNDER","at DANDO SOPA","After years in the corporate world, my partner and I ventured into entrepreneurship, founding Dando Sopa — a retail ecommerce business. Its name was inspired by a Brazilian expression akin to 'up for grabs'.","logo-dando-sopa.png","2022-08-01","FULL STACK DEVELOPER","at VISIAN SYSTEMS","Worked at a software factory serving UK clients, developing projects including e-commerce platforms, client clustering systems, and a security employee tracking system for Heathrow Airport. Built custom software for the French Government to manage and distribute NGO projects in Africa.","logo-visian.jpg","https://www.visiansystems.com/","2023-02-01",{"_7":8}]
