---
// Bare "/" picks a language client-side (saved choice → browser language →
// default) and redirects to /en or /pt. The meta refresh is the no-JS fallback.
import { DEFAULT_LANG, SUPPORTED_LANGS } from "../i18n";
import { withBase } from "../utils/withBase";

// Base with a guaranteed trailing slash — the script appends the lang to it.
const base = withBase("");
const fallback = withBase(`${DEFAULT_LANG}/`);
---

<html lang={DEFAULT_LANG}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${fallback}`} />
    <title>Gustavo Rizzo — Résumé</title>
    <script
      is:inline
      define:vars={{ base, langs: SUPPORTED_LANGS, fallbackLang: DEFAULT_LANG }}
    >
      const saved = window.localStorage.getItem("resume.lang");
      const browser = (navigator.language || "").slice(0, 2);
      const lang = langs.indexOf(saved) >= 0 ? saved : langs.indexOf(browser) >= 0 ? browser : fallbackLang;
      window.location.replace(base + lang + "/");
    </script>
  </head>
  <body></body>
</html>
