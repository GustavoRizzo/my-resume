---
// Served by GitHub Pages for any unknown URL under the repo path. Every real
// route is a prerendered HTML file, so no SPA-restore trickery is needed.
import "../styles/global.scss";
import { DEFAULT_LANG } from "../i18n";

const home = `${import.meta.env.BASE_URL}${DEFAULT_LANG}/`;
---

<html lang={DEFAULT_LANG}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>Not Found — Gustavo Rizzo</title>
  </head>
  <body>
    <div id="root">
      <main style="padding: 2rem; text-align: center;">
        <h1 class="hero-title">404</h1>
        <p>There's nothing here!</p>
        <p><a href={home} style="color: inherit;">← Gustavo Rizzo — Résumé</a></p>
      </main>
    </div>
  </body>
</html>
