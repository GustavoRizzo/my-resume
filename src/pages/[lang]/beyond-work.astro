---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LanguageSelector from "../../components/LanguageSelector/LanguageSelector.astro";
import { getEntry } from "astro:content";
import { SUPPORTED_LANGS, t, type Lang } from "../../i18n";

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const hobbies = (await getEntry("hobbies", lang))!.data;
const resume = (await getEntry("resume", lang))!.data;
---

<BaseLayout lang={lang} title={`${t(lang, "nav.beyondWork")} — ${resume.about.name}`}>
  <LanguageSelector lang={lang} />
  <main style="padding: 0 1rem">
    <h2 class="section-title">{hobbies.section.title}</h2>
    <p>{hobbies.section.subtitle}</p>
    <!-- Fase 6: BeyondWork cards + modal island -->
  </main>
</BaseLayout>
