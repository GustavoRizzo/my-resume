---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LanguageSelector from "../../components/LanguageSelector/LanguageSelector.astro";
import WhoAmI from "../../components/WhoAmI/WhoAmI";
import { getEntry } from "astro:content";
import { SUPPORTED_LANGS, t, type Lang } from "../../i18n";

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const resume = (await getEntry("resume", lang))!.data;
---

<BaseLayout lang={lang} page="about" path="/about">
  <LanguageSelector lang={lang} />
  <main style="padding: 0 1rem">
    <WhoAmI client:load {...resume.about} />
  </main>
</BaseLayout>
