[{"_1":2,"_3":4},"routes/lang-layout",{"_5":160},"routes/lang-home",{"_5":6},"data",{"_7":8,"_9":10},"lang","pt","content",{"_11":12,"_13":14,"_15":16,"_17":18},"about",{"_139":140,"_141":142,"_143":144,"_145":146,"_147":148},"expertises",[117,118,119],"experiences",[67,68,69,70,71,72,73,74],"hobbies",{"_19":20,"_21":22},"section",{"_30":64,"_65":66},"topics",[23,24,25],{"_26":58,"_28":59,"_30":60,"_32":61,"_34":62,"_36":63},{"_26":48,"_28":49,"_30":50,"_32":51,"_34":52,"_36":53},{"_26":27,"_28":29,"_30":31,"_32":33,"_34":35,"_36":37},"id","side-projects","emoji","🛠️","title","Ferramentas & Passatempos que Crio","summary","Pegando pequenos incômodos do dia a dia e programando minha própria solução.","body_html","<p>Adoro pegar um pequeno problema do dia a dia e construir minha própria solução para ele. Aqui estão alguns deles:</p><ul><li><b>Quem?</b> — uma versão web gratuita e sem anúncios do jogo de festa \"Quem sou eu?\" que jogo com os amigos. Os apps na Play Store são tomados por anúncios e barreiras pagas, então criei o meu próprio.</li><li><b>Conversor PTAX</b> — no Brasil, faturar para clientes estrangeiros significa converter os valores usando uma taxa especial do Banco Central. O site oficial é difícil de usar, então peguei a API deles e a embrulhei em uma interface mais agradável.</li></ul>","links",[38,39],{"_40":46,"_42":47,"_44":45},{"_40":41,"_42":43,"_44":45},"label","Conversor PTAX","url","https://gustavorizzo.github.io/conversor-ptax-logger/","note","Grátis · só PT-BR","Jogar \"Quem?\"","https://gustavorizzo.github.io/game-quem-sou-eu/","open-source","🌱","Código Aberto","Construindo sobre as soluções uns dos outros para que todos tenhamos uma tecnologia melhor.","<p>Adoro a ideia por trás do código aberto: a solução de uma pessoa pode se tornar um trampolim para o problema de outra — e essa pessoa pode retribuir da mesma forma. No fim, todos nos beneficiamos de uma tecnologia mais madura e mais capaz.</p><p>No momento estou contribuindo com uma biblioteca de componentes <b>Django&nbsp;+&nbsp;HTMX</b>, onde venho reunindo os padrões que uso todos os dias enquanto construo projetos reais.</p>",[54],{"_40":55,"_42":56,"_44":57},"django-sample-components","https://pypi.org/project/django-sample-components/","PyPI","outdoors","🥾","Aventuras & Esportes","Trilhas, montanhas, vôlei e uma boa pelada de futebol.","<p>Adoro natureza, e fazer trilhas 🏔️. Já escalei alguns dos picos mais altos do Brasil e já fiz uma trilha de <b>250&nbsp;km</b> de distância até Aparecida. Meu próximo grande sonho — que pretendo realizar em breve — é fazer o <b>Caminho de Santiago</b>. Quando não estou em uma trilha, você me encontra jogando vôlei 🏐 ou, como todo bom brasileiro, futebol ⚽.</p>",[],"Além do Trabalho","subtitle","O que eu faço longe do teclado — e algumas coisas que construo só por diversão.",{"_30":111,"_65":112,"_77":113,"_79":114,"_81":115,"_83":116},{"_30":106,"_65":107,"_77":108,"_79":109,"_83":110},{"_30":103,"_65":95,"_77":104,"_79":97,"_81":98,"_83":105},{"_30":100,"_65":95,"_77":101,"_79":97,"_81":98,"_83":102},{"_30":94,"_65":95,"_77":96,"_79":97,"_81":98,"_83":99},{"_30":91,"_65":86,"_77":92,"_79":88,"_81":89,"_83":93},{"_30":85,"_65":86,"_77":87,"_79":88,"_81":89,"_83":90},{"_30":75,"_65":76,"_77":78,"_79":80,"_81":82,"_83":84},"ESTAGIÁRIO DE DESENVOLVIMENTO WEB","na PUC-RIO no LIRA, o LABORATÓRIO de INTELIGÊNCIA ROBÓTICA APLICADA","text","Atuei na manutenção e atualização do site do laboratório, além de auxiliar os pesquisadores em pequenas tarefas.","company_logo","PUC-Rio-Logo.jpg","company_url","https://www.puc-rio.br/","initial_date","2017-02-01","ESTAGIÁRIO DE RELACIONAMENTO COM O CLIENTE","na STONE CO","Responsável pelo atendimento a dúvidas e necessidades dos clientes via e-mail, telefone e chat, esclarecendo questões relacionadas aos produtos e conduzindo renegociações de taxas.","logo-stone.jpg","https://investors.stone.co/","2017-05-01","ANALISTA DE DADOS EM LOGÍSTICA","Responsável por gerar e automatizar relatórios de KPIs sobre a logística interna em todo o Brasil e discuti-los com os líderes de cada filial para criar planos de melhoria.","2017-11-01","DESENVOLVEDOR DE SOFTWARE","na ATIVA INVESTIMENTOS","Responsável pela evolução e manutenção tanto de aplicações utilizadas pelos clientes da empresa quanto das plataformas internas dos funcionários. Stack: Azure, C# (.Net Core), Asp.Net e VUE.js.","logo-ativa.jpg","https://www.ativainvestimentos.com.br/","2018-01-01","GERENTE DE PROJETOS","Gerenciei tanto equipes internas de desenvolvimento quanto membros terceirizados. Prestei orientação e suporte na área de sistemas de corretagem de ações, gestão de risco, fundos de investimento e captação de clientes.","2019-07-01","ANALISTA DE DADOS","Cofundei a equipe de dados da companhia, estruturando todo o ambiente analítico desde a extração e enriquecimento de dados com Pentaho e SSIS, até a modelagem em Data Warehouse via Python e SSAS, finalizando na entrega de dashboards em Power BI. O objetivo era não apenas fornecer dados estratégicos para o nível executivo, mas também disseminar a cultura analítica e o ferramental necessário para empoderar as áreas operacionais.","2020-11-01","FUNDADOR","na DANDO SOPA","Após anos no mundo corporativo, me aventurei com mais um sócio no empreendedorismo, fundando a Dando Sopa — um negócio de e-commerce varejista.","logo-dando-sopa.png","2022-08-01","DESENVOLVEDOR FULL STACK","na VISIAN SYSTEMS","Atuação como Desenvolvedor Sênior em uma software house britânica com projetos globais. Desenvolvimento de plataformas de e-commerce, sistemas de inteligência de clusterização de clientes e soluções de alta segurança, como o sistema de rastreamento de funcionários para o Aeroporto de Heathrow e a plataforma de avaliação de projetos de ONGs para captação de recursos junto ao Governo Francês.","logo-visian.jpg","https://www.visiansystems.com/","2023-02-01",{"_30":134,"_121":135,"_123":136,"_125":137,"_127":138,"_83":116},{"_30":129,"_121":130,"_123":131,"_125":132,"_127":133,"_83":116},{"_30":120,"_121":122,"_123":124,"_125":126,"_127":128,"_83":116},"Gerente de Projetos","html_text","Gerenciei tanto equipes internas de desenvolvimento quanto terceirizadas em projetos das squads de plataforma de trade, fundos de investimento e gestão de risco.","url_img","https://cdn-icons-png.flaticon.com/32/1556/1556324.png","icon","engine","underline_class_css","underline-orange","Analista de Dados","<p><b>Data Visualization Tools:</b></p><ul><li>Power BI</li><li>Streamlit</li></ul><p><b>ETL Tools:</b></p><ul><li>Apache Spark</li><li>SSIS</li><li>Pentaho</li></ul><p><b>Databases:</b></p><ul style='text-align: left'><li><b>Relational:</b> <span>SQLServer, Oracle, PostgreSQL, MySQL</span></li><li><b>NoSQL:</b> <span>MongoDB</span></li><li><b>OLAP:</b> <span>SSAS, DuckDB</span></li></ul>","https://cdn-icons-png.flaticon.com/32/2329/2329087.png","presentation","underline-blue","Desenvolvedor de Software","<p><b>Backend:</b><br><ul><li>Python (Django, FastAPI)</li><li>C# (.Net Core)</li></ul></p><p><b>Frontend:</b><ul><li>JavaScript/Typescript (VUE, React, NextJS)</li></ul></p><p><b>DevOps:</b><ul><li>Docker</li><li>Cloud (Azure, AWS)</li></ul></p>","https://cdn-icons-png.flaticon.com/32/9423/9423061.png","web","underline-megenta","perfil_img","perfil.png","name","Gustavo Rizzo S. M. de Albuquerque","url_linkedin","https://www.linkedin.com/in/gustavo-albuquerque/","url_github","https://github.com/GustavoRizzo","console_phrases",[149,150,151,152],{"_153":134,"_155":159},{"_153":129,"_155":158},{"_153":120,"_155":157},{"_153":154,"_155":156},"phrase","Apaixonado por Tecnologia","color","chartreuse","gold","fuchsia","tomato",{"_7":8}]
